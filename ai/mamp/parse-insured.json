  "data_row_rules": {
    "require_serial_number": true,
    "require_surname": true,
    "require_name_or_policy": true,
    "reject_underscore_in_name": true
  },

  "date_fields": ["birth_date", "service_start", "service_end"],

  "excel_date": {
    "min_serial": 20000,
    "max_serial": 100000,
    "min_year": 1900,
    "max_year": 2100
  },

  "header_match_rules": {
    "includes_min_alias_length": 8,
    "starts_with_min_alias_length": 10
  },

  "program_normalize": {
    "separator": "+",
    "order": ["АПП", "ПНД", "СТОМ"],
    "components": {
      "АПП": {
        "keywords": [
          "апп",
          "поликлин",
          "амбулатор",
          "амбулаторная помощь",
          "амбулаторно-поликлиническое"
        ],
        "letter_codes": ["п"]
      },
      "ПНД": {
        "keywords": [
          "пнд",
          "помощь на дому",
          "вызов на дом",
          "вызов врача",
          "на дому"
        ],
        "letter_codes": ["в"]
      },
      "СТОМ": {
        "keywords": [
          "стом",
          "стоматолог"
        ],
        "letter_codes": ["с"]
      }
    }
  },

  "errors": {
